# ============================================================
# simple-ai-gateway env 模板
# 复制为 .env 后填入实际值: cp .env.example .env
# ============================================================

# Admin root token — 用于首次登录管理 API / UI
# 生成方式: openssl rand -hex 32
GATEWAY_ROOT_TOKEN=

# 落库凭证的加密 master key (base64, 32 字节)
# 生成方式: openssl rand -base64 32
# !!! 丢失即无法解密历史数据,务必备份 !!!
GATEWAY_MASTER_KEY=

# 上游供应商凭证(被 config 中的 env://OPENAI_API_KEY 等引用)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# 日志级别 (tracing EnvFilter 语法)
RUST_LOG=info,sqlx::query=warn

# 可选: 指定配置文件路径,等价于 --config
# GATEWAY_CONFIG=config/example.lite.yaml
